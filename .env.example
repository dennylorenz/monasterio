# Email sender address (must match MAIL_DOMAIN for deliverability)
FROM_EMAIL=reservas@monasterio.es
BCC_EMAIL=denny@kolor-berlin.com

# Mail domain (used by Postfix to identify itself)
MAIL_DOMAIN=monasterio.es

# SMTP settings (auto-configured in Docker — override for external relay)
# SMTP_HOST=mail
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Telegram notifications (optional)
# Create a bot via @BotFather, then message your bot once to get a chat_id
# from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Server
PORT=3001
